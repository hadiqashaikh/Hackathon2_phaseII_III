e":"assistant"},{"content":"delete my first task \"buy grocorie\"","conversation_id":"4495e991-22d4-46d9-a6b6-068040ce28f2","created_at":"2026-03-09T08:45:05.498833","id":"23f0f110-a432-45d1-848d-644d1f0bbfee","role":"user"},{"content":"Done! I've deleted the task: Buy grocerie. If there's anything else you need, feel free to ask!","conversation_id":"4495e991-22d4-46d9-a6b6-068040ce28f2","created_at":"2026-03-09T08:45:14.239480","id":"c5bfe2f4-e189-4a32-a345-42ef08ae41d3","role":"assistant"},{"content":"Add a task to buy groceries and another one to pay the internet bill tomorrow.","conversation_id":"4495e991-22d4-46d9-a6b6-068040ce28f2","created_at":"2026-03-09T17:03:08.920944","id":"d5357e3d-a723-4ffc-a4de-da0f143def05","role":"user"},{"content":"I've added the tasks: \n\n1. Buy groceries\n2. Pay the internet bill tomorrow\n\nIf there's anything more you need, just let me know!","conversation_id":"4495e991-22d4-46d9-a6b6-068040ce28f2","created_at":"2026-03-09T17:03:21.035917","id":"8751cdc4-9516-4ac3-a654-fb5a7adc7d9d","role":"assistant"},{"content":"delete a first task","conversation_id":"4495e991-22d4-46d9-a6b6-068040ce28f2","created_at":"2026-03-09T17:04:03.605798","id":"6a95bba2-1a6d-4a0e-9e48-102f4630c419","role":"user"},{"content":"I've deleted the task: Buy groceries. If you need anything else, just let me know!","conversation_id":"4495e991-22d4-46d9-a6b6-068040ce28f2","created_at":"2026-03-09T17:04:14.393235","id":"78bf1473-beb7-4d67-a79b-35db7931bf04","role":"assistant"}]}
